# Shopify OAuth Configuration
# Copy this file to .env.local and fill in your credentials

# Shopify App Credentials
# Get these from your Shopify Partner Dashboard:
# 1. Login to https://partners.shopify.com
# 2. Create a new app in your store
# 3. Copy Client ID and Client Secret from App credentials
VITE_SHOPIFY_CLIENT_ID=your-shopify-client-id-here
VITE_SHOPIFY_CLIENT_SECRET=your-shopify-client-secret-here

# Redirect URI must match what's configured in Shopify App settings
# For local development:
VITE_SHOPIFY_REDIRECT_URI=http://localhost:5173/auth/shopify/callback

# Shopify API version
VITE_SHOPIFY_API_VERSION=2025-01

# Optional: Set to 'false' to require env vars instead of falling back to test app
VITE_SHOPIFY_ALLOW_FALLBACK=true

# Gemini AI Insights Configuration
# Get API key from Google AI Studio: https://aistudio.google.com/app/apikey
# This enables AI-powered insights dashboard for vendors
VITE_GEMINI_API_KEY=your-gemini-api-key-here
