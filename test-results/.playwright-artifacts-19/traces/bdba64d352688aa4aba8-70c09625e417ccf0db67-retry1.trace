p-grayscale:  ;\n  --tw-backdrop-hue-rotate:  ;\n  --tw-backdrop-invert:  ;\n  --tw-backdrop-opacity:  ;\n  --tw-backdrop-saturate:  ;\n  --tw-backdrop-sepia:  ;\n  --tw-contain-size:  ;\n  --tw-contain-layout:  ;\n  --tw-contain-paint:  ;\n  --tw-contain-style:  ;\n}\n\n::backdrop{\n  --tw-border-spacing-x: 0;\n  --tw-border-spacing-y: 0;\n  --tw-translate-x: 0;\n  --tw-translate-y: 0;\n  --tw-rotate: 0;\n  --tw-skew-x: 0;\n  --tw-skew-y: 0;\n  --tw-scale-x: 1;\n  --tw-scale-y: 1;\n  --tw-pan-x:  ;\n  --tw-pan-y:  ;\n  --tw-pinch-zoom:  ;\n  --tw-scroll-snap-strictness: proximity;\n  --tw-gradient-from-position:  ;\n  --tw-gradient-via-position:  ;\n  --tw-gradient-to-position:  ;\n  --tw-ordinal:  ;\n  --tw-slashed-zero:  ;\n  --tw-numeric-figure:  ;\n  --tw-numeric-spacing:  ;\n  --tw-numeric-fraction:  ;\n  --tw-ring-inset:  ;\n  --tw-ring-offset-width: 0px;\n  --tw-ring-offset-color: #fff;\n  --tw-ring-color: rgb(59 130 246 / 0.5);\n  --tw-ring-offset-shadow: 0 0 #0000;\n  --tw-ring-shadow: 0 0 #0000;\n  --tw-shadow: 0 0 #0000;\n  --tw-shadow-colored: 0 0 #0000;\n  --tw-blur:  ;\n  --tw-brightness:  ;\n  --tw-contrast:  ;\n  --tw-grayscale:  ;\n  --tw-hue-rotate:  ;\n  --tw-invert:  ;\n  --tw-saturate:  ;\n  --tw-sepia:  ;\n  --tw-drop-shadow:  ;\n  --tw-backdrop-blur:  ;\n  --tw-backdrop-brightness:  ;\n  --tw-backdrop-contrast:  ;\n  --tw-backdrop-grayscale:  ;\n  --tw-backdrop-hue-rotate:  ;\n  --tw-backdrop-invert:  ;\n  --tw-backdrop-opacity:  ;\n  --tw-backdrop-saturate:  ;\n  --tw-backdrop-sepia:  ;\n  --tw-contain-size:  ;\n  --tw-contain-layout:  ;\n  --tw-contain-paint:  ;\n  --tw-contain-style:  ;\n}\n\n/*\n! tailwindcss v3.4.17 | MIT License | https://tailwindcss.com\n*/\n\n/*\n1. Prevent padding and border from affecting element width. (https://github.com/mozdevs/cssremedy/issues/4)\n2. Allow adding a border to an element by just adding a border-width. (https://github.com/tailwindcss/tailwindcss/pull/116)\n*/\n\n*,\n::before,\n::after {\n  box-sizing: border-box; /* 1 */\n  border-width: 0; /* 2 */\n  border-style: solid; /* 2 */\n  border-color: #e5e7eb; /* 2 */\n}\n\n::before,\n::after {\n  --tw-content: '';\n}\n\n/*\n1. Use a consistent sensible line-height in all browsers.\n2. Prevent adjustments of font size after orientation changes in iOS.\n3. Use a more readable tab size.\n4. Use the user's configured `sans` font-family by default.\n5. Use the user's configured `sans` font-feature-settings by default.\n6. Use the user's configured `sans` font-variation-settings by default.\n7. Disable tap highlights on iOS\n*/\n\nhtml,\n:host {\n  line-height: 1.5; /* 1 */\n  -webkit-text-size-adjust: 100%; /* 2 */\n  -moz-tab-size: 4; /* 3 */\n  -o-tab-size: 4;\n     tab-size: 4; /* 3 */\n  font-family: Plus Jakarta Sans, DM Sans, system-ui, sans-serif; /* 4 */\n  font-feature-settings: normal; /* 5 */\n  font-variation-settings: normal; /* 6 */\n  -webkit-tap-highlight-color: transparent; /* 7 */\n}\n\n/*\n1. Remove the margin in all browsers.\n2. Inherit line-height from `html` so users can set them as a class directly on the `html` element.\n*/\n\nbody {\n  margin: 0; /* 1 */\n  line-height: inherit; /* 2 */\n}\n\n/*\n1. Add the correct height in Firefox.\n2. Correct the inheritance of border color in Firefox. (https://bugzilla.mozilla.org/show_bug.cgi?id=190655)\n3. Ensure horizontal rules are visible by default.\n*/\n\nhr {\n  height: 0; /* 1 */\n  color: inherit; /* 2 */\n  border-top-width: 1px; /* 3 */\n}\n\n/*\nAdd the correct text decoration in Chrome, Edge, and Safari.\n*/\n\nabbr:where([title]) {\n  -webkit-text-decoration: underline dotted;\n          text-decoration: underline dotted;\n}\n\n/*\nRemove the default font size and weight for headings.\n*/\n\nh1,\nh2,\nh3,\nh4,\nh5,\nh6 {\n  font-size: inherit;\n  font-weight: inherit;\n}\n\n/*\nReset links to optimize for opt-in styling instead of opt-out.\n*/\n\na {\n  color: inherit;\n  text-decoration: inherit;\n}\n\n/*\nAdd the correct font weight in Edge and Safari.\n*/\n\nb,\nstrong {\n  font-weight: bolder;\n}\n\n/*\n1. Use the user's configured `mono` font-family by default.\n2. Use the user's configured `mono` font-feature-settings by default.\n3. Use the user's configured `mono` font-variation-settings by default.\n4. Correct the odd `em` font sizing in all browsers.\n*/\n\ncode,\nkbd,\nsamp,\npre {\n  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace; /* 1 */\n  font-feature-settings: normal; /* 2 */\n  font-variation-settings: normal; /* 3 */\n  font-size: 1em; /* 4 */\n}\n\n/*\nAdd the correct font size in all browsers.\n*/\n\nsmall {\n  font-size: 80%;\n}\n\n/*\nPrevent `sub` and `sup` elements from affecting the line height in all browsers.\n*/\n\nsub,\nsup {\n  font-size: 75%;\n  line-height: 0;\n  position: relative;\n  vertical-align: baseline;\n}\n\nsub {\n  bottom: -0.25em;\n}\n\nsup {\n  top: -0.5em;\n}\n\n/*\n1. Remove text indentation from table contents in Chrome and Safari. (https://bugs.chromium.org/p/chromium/issues/detail?id=999088, https://bugs.webkit.org/show_bug.cgi?id=201297)\n2. Correct table border color inheritance in all Chrome and Safari. (https://bugs.chromium.org/p/chromium/issues/detail?id=935729, https://bugs.webkit.org/show_bug.cgi?id=195016)\n3. Remove gaps between table borders by default.\n*/\n\ntable {\n  text-indent: 0; /* 1 */\n  border-color: inherit; /* 2 */\n  border-collapse: collapse; /* 3 */\n}\n\n/*\n1. Change the font styles in all browsers.\n2. Remove the margin in Firefox and Safari.\n3. Remove default padding in all browsers.\n*/\n\nbutton,\ninput,\noptgroup,\nselect,\ntextarea {\n  font-family: inherit; /* 1 */\n  font-feature-settings: inherit; /* 1 */\n  font-variation-settings: inherit; /* 1 */\n  font-size: 100%; /* 1 */\n  font-weight: inherit; /* 1 */\n  line-height: inherit; /* 1 */\n  letter-spacing: inherit; /* 1 */\n  color: inherit; /* 1 */\n  margin: 0; /* 2 */\n  padding: 0; /* 3 */\n}\n\n/*\nRemove the inheritance of text transform in Edge and Firefox.\n*/\n\nbutton,\nselect {\n  text-transform: none;\n}\n\n/*\n1. Correct the inability to style clickable types in iOS and Safari.\n2. Remove default button styles.\n*/\n\nbutton,\ninput:where([type='button']),\ninput:where([type='reset']),\ninput:where([type='submit']) {\n  -webkit-appearance: button; /* 1 */\n  background-color: transparent; /* 2 */\n  background-image: none; /* 2 */\n}\n\n/*\nUse the modern Firefox focus style for all focusable elements.\n*/\n\n:-moz-focusring {\n  outline: auto;\n}\n\n/*\nRemove the additional `:invalid` styles in Firefox. (https://github.com/mozilla/gecko-dev/blob/2f9eacd9d3d995c937b4251a5557d95d494c9be1/layout/style/res/forms.css#L728-L737)\n*/\n\n:-moz-ui-invalid {\n  box-shadow: none;\n}\n\n/*\nAdd the correct vertical alignment in Chrome and Firefox.\n*/\n\nprogress {\n  vertical-align: baseline;\n}\n\n/*\nCorrect the cursor style of increment and decrement buttons in Safari.\n*/\n\n::-webkit-inner-spin-button,\n::-webkit-outer-spin-button {\n  height: auto;\n}\n\n/*\n1. Correct the odd appearance in Chrome and Safari.\n2. Correct the outline style in Safari.\n*/\n\n[type='search'] {\n  -webkit-appearance: textfield; /* 1 */\n  outline-offset: -2px; /* 2 */\n}\n\n/*\nRemove the inner padding in Chrome and Safari on macOS.\n*/\n\n::-webkit-search-decoration {\n  -webkit-appearance: none;\n}\n\n/*\n1. Correct the inability to style clickable types in iOS and Safari.\n2. Change font properties to `inherit` in Safari.\n*/\n\n::-webkit-file-upload-button {\n  -webkit-appearance: button; /* 1 */\n  font: inherit; /* 2 */\n}\n\n/*\nAdd the correct display in Chrome and Safari.\n*/\n\nsummary {\n  display: list-item;\n}\n\n/*\nRemoves the default spacing and border for appropriate elements.\n*/\n\nblockquote,\ndl,\ndd,\nh1,\nh2,\nh3,\nh4,\nh5,\nh6,\nhr,\nfigure,\np,\npre {\n  margin: 0;\n}\n\nfieldset {\n  margin: 0;\n  padding: 0;\n}\n\nlegend {\n  padding: 0;\n}\n\nol,\nul,\nmenu {\n  list-style: none;\n  margin: 0;\n  padding: 0;\n}\n\n/*\nReset default styling for dialogs.\n*/\n\ndialog {\n  padding: 0;\n}\n\n/*\nPrevent resizing textareas horizontally by default.\n*/\n\ntextarea {\n  resize: vertical;\n}\n\n/*\n1. Reset the default placeholder opacity in Firefox. (https://github.com/tailwindlabs/tailwindcss/issues/3300)\n2. Set the default placeholder color to the user's configured gray 400 color.\n*/\n\ninput::-moz-placeholder, textarea::-moz-placeholder {\n  opacity: 1; /* 1 */\n  color: #9ca3af; /* 2 */\n}\n\ninput::placeholder,\ntextarea::placeholder {\n  opacity: 1; /* 1 */\n  color: #9ca3af; /* 2 */\n}\n\n/*\nSet the default cursor for buttons.\n*/\n\nbutton,\n[role=\"button\"] {\n  cursor: pointer;\n}\n\n/*\nMake sure disabled buttons don't get the pointer cursor.\n*/\n\n:disabled {\n  cursor: default;\n}\n\n/*\n1. Make replaced elements `display: block` by default. (https://github.com/mozdevs/cssremedy/issues/14)\n2. Add `vertical-align: middle` to align replaced elements more sensibly by default. (https://github.com/jensimmons/cssremedy/issues/14#issuecomment-634934210)\n   This can trigger a poorly considered lint error in some tools but is included by design.\n*/\n\nimg,\nsvg,\nvideo,\ncanvas,\naudio,\niframe,\nembed,\nobject {\n  display: block; /* 1 */\n  vertical-align: middle; /* 2 */\n}\n\n/*\nConstrain images and videos to the parent width and preserve their intrinsic aspect ratio. (https://github.com/mozdevs/cssremedy/issues/14)\n*/\n\nimg,\nvideo {\n  max-width: 100%;\n  height: auto;\n}\n\n/* Make elements with the HTML hidden attribute stay hidden by default */\n\n[hidden]:where(:not([hidden=\"until-found\"])) {\n  display: none;\n}\n\n:root {\n    --background: 276 38% 94%;\n    --foreground: 270 30% 12%;\n\n    --card: 0 0% 100%;\n    --card-foreground: 270 30% 12%;\n\n    --popover: 0 0% 100%;\n    --popover-foreground: 270 30% 12%;\n\n    /* #2B0D3E */\n    --primary: 276 65% 15%;\n    --primary-foreground: 276 38% 96%;\n\n    --secondary: 276 30% 91%;\n    --secondary-foreground: 270 30% 15%;\n\n    --muted: 280 30% 90%;\n    --muted-foreground: 270 20% 30%;\n\n    /* #7A3F91 */\n    --accent: 284 40% 41%;\n    --accent-foreground: 0 0% 100%;\n\n    --destructive: 0 68% 55%;\n    --destructive-foreground: 0 0% 100%;\n\n    --success: 158 58% 42%;\n    --success-foreground: 0 0% 100%;\n\n    --warning: 38 88% 52%;\n    --warning-foreground: 38 88% 10%;\n\n    --info: 220 75% 55%;\n    --info-foreground: 0 0% 100%;\n\n    /* #C59DD9 tinted borders */\n    --border: 280 28% 86%;\n    --input: 280 28% 84%;\n    --ring: 284 40% 41%;\n\n    --radius: 1rem;\n\n    --amazon: 33 100% 50%;\n    --flipkart: 45 100% 51%;\n    --meesho: 340 82% 52%;\n    --firstcry: 199 89% 48%;\n    --blinkit: 45 100% 51%;\n    --myntra: 350 80% 55%;\n    --nykaa: 330 70% 50%;\n    --ajio: 210 70% 45%;\n\n    --chart-1: 276 65% 15%;\n    --chart-2: 284 40% 41%;\n    --chart-3: 280 40% 73%;\n    --chart-4: 38 88% 52%;\n    --chart-5: 158 58% 42%;\n\n    /* Liquid Glass Tokens */\n    --glass-bg: rgba(255, 255, 255, 0.12);\n    --glass-bg-medium: rgba(255, 255, 255, 0.18);\n    --glass-bg-strong: rgba(255, 255, 255, 0.35);\n    --glass-bg-card: rgba(255, 255, 255, 0.45);\n    --glass-border: rgba(255, 255, 255, 0.25);\n    --glass-border-strong: rgba(255, 255, 255, 0.45);\n    --glass-highlight: rgba(255, 255, 255, 0.6);\n    --glass-blur: 24px;\n    --glass-blur-heavy: 40px;\n\n    /* Gradient Palette */\n    --gradient-primary: linear-gradient(135deg, #C59DD9 0%, #7A3F91 100%);\n    --gradient-primary-hover: linear-gradient(135deg, #d4aee3 0%, #8a4fa1 100%);\n    --gradient-deep: linear-gradient(135deg, #7A3F91 0%, #2B0D3E 100%);\n    --gradient-card: linear-gradient(160deg, rgba(255,255,255,0.5) 0%, rgba(242,234,247,0.3) 100%);\n    --gradient-glow: linear-gradient(135deg, rgba(197,157,217,0.4) 0%, rgba(122,63,145,0.2) 100%);\n    --gradient-surface: linear-gradient(180deg, rgba(255,255,255,0.15) 0%, rgba(255,255,255,0.05) 100%);\n\n    /* Purple glow shadows */\n    --shadow-sm: 0 2px 8px -2px rgba(122, 63, 145, 0.08);\n    --shadow-md: 0 8px 24px -6px rgba(122, 63, 145, 0.12), 0 4px 12px -4px rgba(43, 13, 62, 0.06);\n    --shadow-lg: 0 16px 40px -8px rgba(122, 63, 145, 0.16), 0 8px 20px -6px rgba(43, 13, 62, 0.08);\n    --shadow-xl: 0 24px 56px -12px rgba(122, 63, 145, 0.2), 0 12px 28px -8px rgba(43, 13, 62, 0.1);\n    --shadow-glow: 0 0 20px rgba(197, 157, 217, 0.3), 0 0 40px rgba(122, 63, 145, 0.15);\n    --shadow-glow-strong: 0 0 30px rgba(197, 157, 217, 0.45), 0 0 60px rgba(122, 63, 145, 0.2);\n    --shadow-inner-glass: inset 0 1px 2px rgba(255, 255, 255, 0.3), inset 0 -1px 2px rgba(43, 13, 62, 0.05);\n\n    /* Sidebar */\n    --sidebar-background: 276 65% 12%;\n    --sidebar-foreground: 276 20% 92%;\n    --sidebar-primary: 284 40% 41%;\n    --sidebar-primary-foreground: 0 0% 100%;\n    --sidebar-accent: 276 50% 20%;\n    --sidebar-accent-foreground: 276 20% 92%;\n    --sidebar-border: 276 55% 18%;\n    --sidebar-ring: 284 40% 41%;\n  }\n\n.dark {\n    --background: 280 50% 5%;\n    --foreground: 280 20% 92%;\n\n    --card: 280 45% 8%;\n    --card-foreground: 280 20% 92%;\n\n    --popover: 280 45% 8%;\n    --popover-foreground: 280 20% 92%;\n\n    --primary: 280 40% 60%;\n    --primary-foreground: 0 0% 100%;\n\n    --secondary: 280 35% 14%;\n    --secondary-foreground: 280 20% 90%;\n\n    --muted: 280 30% 12%;\n    --muted-foreground: 275 15% 65%;\n\n    --accent: 284 35% 48%;\n    --accent-foreground: 0 0% 100%;\n\n    --destructive: 0 58% 50%;\n    --destructive-foreground: 0 0% 100%;\n\n    --success: 158 55% 40%;\n    --success-foreground: 0 0% 100%;\n\n    --warning: 38 85% 50%;\n    --warning-foreground: 38 85% 10%;\n\n    --info: 220 70% 50%;\n    --info-foreground: 0 0% 100%;\n\n    --border: 280 30% 16%;\n    --input: 280 30% 16%;\n    --ring: 284 40% 50%;\n\n    --glass-bg: rgba(43, 13, 62, 0.3);\n    --glass-bg-medium: rgba(43, 13, 62, 0.4);\n    --glass-bg-strong: rgba(43, 13, 62, 0.55);\n    --glass-bg-card: rgba(43, 13, 62, 0.5);\n    --glass-border: rgba(197, 157, 217, 0.12);\n    --glass-border-strong: rgba(197, 157, 217, 0.2);\n    --glass-highlight: rgba(197, 157, 217, 0.15);\n\n    --gradient-card: linear-gradient(160deg, rgba(43,13,62,0.4) 0%, rgba(43,13,62,0.2) 100%);\n    --gradient-surface: linear-gradient(180deg, rgba(197,157,217,0.08) 0%, rgba(197,157,217,0.02) 100%);\n\n    --shadow-sm: 0 2px 8px -2px rgba(0,0,0, 0.3);\n    --shadow-md: 0 8px 24px -6px rgba(0,0,0, 0.4);\n    --shadow-lg: 0 16px 40px -8px rgba(0,0,0, 0.45);\n    --shadow-xl: 0 24px 56px -12px rgba(0,0,0, 0.5);\n    --shadow-glow: 0 0 20px rgba(122, 63, 145, 0.2);\n    --shadow-glow-strong: 0 0 30px rgba(122, 63, 145, 0.3);\n    --shadow-inner-glass: inset 0 1px 2px rgba(197,157,217,0.1), inset 0 -1px 2px rgba(0,0,0,0.1);\n\n    --sidebar-background: 280 50% 5%;\n    --sidebar-foreground: 280 20% 88%;\n    --sidebar-primary: 284 40% 48%;\n    --sidebar-primary-foreground: 0 0% 100%;\n    --sidebar-accent: 280 35% 12%;\n    --sidebar-accent-foreground: 280 20% 88%;\n    --sidebar-border: 280 30% 12%;\n    --sidebar-ring: 284 40% 50%;\n  }\n\n*{\n  border-color: hsl(var(--border));\n}\n\nbody{\n  background-color: hsl(var(--background));\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n    font-family: 'Plus Jakarta Sans', 'DM Sans', system-ui, sans-serif;\n    font-size: 14px;\n    line-height: 1.6;\n    color: hsl(var(--foreground));\n    background: linear-gradient(160deg, #F2EAF7 0%, #e8d8f0 30%, #f0e6f5 60%, #F2EAF7 100%);\n    background-attachment: fixed;\n}\n\n.dark body,\n  body:is(.dark *) {\n    background: linear-gradient(160deg, #1a0628 0%, #120420 35%, #0d0318 70%, #1a0628 100%);\n    background-attachment: fixed;\n  }\n\nh1, h2, h3, h4, h5, h6 {\n    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;\n    letter-spacing: -0.02em;\n    color: hsl(var(--foreground));\n    font-weight: 700;\n  }\n\nh1 { font-size: 1.75rem; line-height: 1.25; }\n\nh2 { font-size: 1.375rem; line-height: 1.3; }\n\nh3 { font-size: 1.125rem; line-height: 1.35; font-weight: 600; }\n\nh4 { font-size: 1rem; line-height: 1.4; font-weight: 600; }\n\np, span, li, td, th, label, a {\n    color: hsl(var(--foreground));\n    line-height: 1.6;\n  }\n\nsmall, .text-xs {\n    font-size: 0.75rem;\n    line-height: 1.5;\n  }\n\n.text-sm {\n    font-size: 0.8125rem;\n    line-height: 1.55;\n  }\n\n.text-muted-foreground {\n    color: hsl(var(--muted-foreground)) !important;\n  }\n\n.container{\n  width: 100%;\n  margin-right: auto;\n  margin-left: auto;\n  padding-right: 2rem;\n  padding-left: 2rem;\n}\n\n@media (min-width: 1400px){\n\n  .container{\n    max-width: 1400px;\n  }\n}\n\n/* === LIQUID GLASS CORE === */\n\n.glass-card {\n    background: var(--glass-bg-card);\n    backdrop-filter: blur(var(--glass-blur-heavy));\n    -webkit-backdrop-filter: blur(var(--glass-blur-heavy));\n    border: 1px solid var(--glass-border-strong);\n    box-shadow: var(--shadow-md), var(--shadow-inner-glass);\n    border-radius: calc(var(--radius) + 8px);\n    transition-property: all;\n    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n    transition-duration: 300ms;\n    animation-duration: 300ms;\n  }\n\n.glass-card:hover {\n    box-shadow: var(--shadow-lg), var(--shadow-inner-glass), var(--shadow-glow);\n    border-color: rgba(197, 157, 217, 0.4);\n    transform: translateY(-2px) scale(1.005);\n  }\n\n.glass-panel {\n    background: var(--glass-bg-strong);\n    backdrop-filter: blur(var(--glass-blur-heavy));\n    -webkit-backdrop-filter: blur(var(--glass-blur-heavy));\n    border: 1px solid var(--glass-border);\n    box-shadow: var(--shadow-inner-glass);\n    border-radius: calc(var(--radius) + 8px);\n  }\n\n/* KPI Cards */\n\n.kpi-card {\n    background: var(--glass-bg-card);\n    backdrop-filter: blur(var(--glass-blur-heavy));\n    -webkit-backdrop-filter: blur(var(--glass-blur-heavy));\n    border: 1px solid var(--glass-border-strong);\n    box-shadow: var(--shadow-md), var(--shadow-inner-glass);\n    border-radius: calc(var(--radius) + 8px);\n    padding: 1.5rem;\n    transition-property: all;\n    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n    transition-duration: 300ms;\n    animation-duration: 300ms;\n    position: relative;\n    overflow: hidden;\n  }\n\n.kpi-card::before {\n    content: '';\n    position: absolute;\n    top: 0;\n    left: 0;\n    right: 0;\n    height: 50%;\n    background: var(--gradient-surface);\n    pointer-events: none;\n    border-radius: inherit;\n  }\n\n.kpi-card:hover {\n    box-shadow: var(--shadow-xl), var(--shadow-inner-glass), var(--shadow-glow);\n    transform: translateY(-3px) scale(1.01);\n    border-color: rgba(197, 157, 217, 0.5);\n  }\n\n/* Status Badges */\n\n/* Data Table – Glass */\n\n/* Nav items */\n\n.nav-item.\\!active {\n    background: var(--gradient-primary) !important;\n    color: white !important;\n    font-weight: 500 !important;\n    box-shadow: var(--shadow-glow) !important;\n  }\n\n.nav-item.active {\n    background: var(--gradient-primary);\n    color: white;\n    font-weight: 500;\n    box-shadow: var(--shadow-glow);\n  }\n\n/* Chart Container */\n\n.chart-container {\n    background: var(--glass-bg-card);\n    backdrop-filter: blur(var(--glass-blur-heavy));\n    -webkit-backdrop-filter: blur(var(--glass-blur-heavy));\n    border: 1px solid var(--glass-border-strong);\n    box-shadow: var(--shadow-md), var(--shadow-inner-glass);\n    border-radius: calc(var(--radius) + 8px);\n    padding: 1.5rem;\n  }\n\n/* Alert Styles */\n\n.alert-critical{\n  border-radius: calc(var(--radius) + 4px);\n  border-left-width: 4px;\n  border-left-color: hsl(var(--destructive));\n    background: rgba(220, 70, 70, 0.06);\n    backdrop-filter: blur(16px);\n}\n\n.alert-warning{\n  border-radius: calc(var(--radius) + 4px);\n  border-left-width: 4px;\n  border-left